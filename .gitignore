# Large / downloaded data (real-data experiments)
# Use data/* (not data/) so the signedLRBase exception below can re-include it.
data/*
*.txt.gz
*.tar.gz
# ...but keep the generated signedLRBase resource (small, a deliverable)
!data/signedLRBase/

# R session / build artifacts
.Rhistory
.RData
.Rproj.user/
*.Rout

# OS / editor cruft
.DS_Store
